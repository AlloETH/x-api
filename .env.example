# Port the NestJS application listens on
PORT=3000

# RapidAPI credentials for the "Twitter API47" API
# https://rapidapi.com/restocked-gAGxip8a_/api/twitter-api47
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=twitter-api47.p.rapidapi.com
RAPIDAPI_BASE_URL=https://twitter-api47.p.rapidapi.com

# Optional: outbound request timeout (ms)
RAPIDAPI_TIMEOUT=10000

# Throttling (requests per ttl window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# PostgreSQL connection string used to persist fetched user/tweet data.
# For local dev, run `docker compose up -d` to start a matching Postgres
# instance (the default below points at it).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/x_api
